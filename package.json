{
  "name": "gene2-figma-mcp-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Gene2 Figma MCP — Copilot-driven bidirectional sync between code and Figma.",
  "type": "module",
  "workspaces": [
    "packages/gene2-figma-mcp",
    "figma-docs/docs"
  ],
  "scripts": {
    "bridge": "tsx packages/gene2-figma-mcp/src/bridge/server.ts",
    "bridge:mcp": "tsx packages/gene2-figma-mcp/src/bridge/mcp-server.ts",
    "plugin:build": "tsc -p figma-docs/plugin/tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "fmt": "prettier -w .",
    "lint": "eslint .",
    "docs:dev": "cd figma-docs/docs && npm start -- --port 4000",
    "docs:build": "cd figma-docs/docs && npm run build",
    "docs:serve": "cd figma-docs/docs && npm run serve -- --port 4000"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@figma/plugin-typings": "^1.123.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "glob": "^13.0.6",
    "playwright": "^1.58.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
