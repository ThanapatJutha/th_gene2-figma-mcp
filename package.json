{
  "name": "figma-sync",
  "version": "0.1.0",
  "private": true,
  "description": "Copilot-driven bidirectional sync between React code and Figma.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "fmt": "prettier -w .",
    "lint": "eslint .",
    "docs:dev": "cd docs && npm start -- --port 4000",
    "docs:build": "cd docs && npm run build",
    "docs:serve": "cd docs && npm run serve -- --port 4000"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
